# ──────────────────────────────────────────────────────────────────────────
# RelayOps Lead Qualification System — Environment Configuration
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── AI Qualification (Gemini) ──────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── CRM ─────────────────────────────────────────────────────────────────
# Which adapter the CRM factory should instantiate.
# One of: google_sheets | hubspot | gohighlevel | pipedrive | airtable
CRM_PROVIDER=google_sheets

# -- Google Sheets adapter (v1 default) --
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key, keeping \n escape sequences intact.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# -- Future adapters (not used in v1, present for forward-compatibility) --
HUBSPOT_API_KEY=
GOHIGHLEVEL_API_KEY=
PIPEDRIVE_API_KEY=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── Appointment Booking (Calendly) ─────────────────────────────────────
CALENDLY_API_TOKEN=
CALENDLY_EVENT_TYPE_URI=
CALENDLY_WEBHOOK_SIGNING_KEY=
NEXT_PUBLIC_CALENDLY_BOOKING_URL=https://calendly.com/your-org/discovery-call

# ── Email (Founder notifications + lead transactional emails) ──────────
# Development: Gmail SMTP. Swap EMAIL_PROVIDER to "resend" or "sendgrid"
# in production without touching business logic — see src/lib/email.
EMAIL_PROVIDER=gmail_smtp
EMAIL_FROM="RelayOps <no-reply@yourdomain.com>"
FOUNDER_NOTIFICATION_EMAIL=founder@youragency.com

# -- Gmail SMTP (development) --
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=

# -- Resend (production-ready alternative) --
RESEND_API_KEY=

# -- SendGrid (production-ready alternative) --
SENDGRID_API_KEY=

# ── Automation (n8n) ────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ── Future / Out-of-scope toggles (kept off in v1, architecture supports them) ──
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
